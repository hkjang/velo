# ──────────────────────────────────────────────────────────
#  Velo WAS — Environment Variables
#  Copy to .env and fill in your values:
#    cp .env.example .env
# ──────────────────────────────────────────────────────────

# Server port (default: 8080)
VELO_PORT=8080

# JVM options (append to defaults)
VELO_JVM_OPTS=

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Redis URL (for intent routing cache in cluster mode)
VELO_REDIS_URL=redis://redis:6379

# Redis port mapping (default: 6379)
REDIS_PORT=6379

# Grafana admin password
GRAFANA_PASSWORD=admin
